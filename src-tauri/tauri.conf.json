{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "taskforge-frontend",
  "version": "0.1.0",
  "identifier": "com.taskforge.app",
  "build": {
    "frontendDist": "../.next",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "bun run next:dev",
    "beforeBuildCommand": "bun run next:build"
  },
  "app": {
    "windows": [
      {
        "title": "TaskForge",
        "width": 1200,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
